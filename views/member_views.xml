<odoo>

    <!-- list -->
    <record id="view_library_member_list" model="ir.ui.view">
        <field name="name">library.member.list</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <list>
                <field name="member_code"/>
                <field name="name"/>
                <field name="email"/>
                <field name="status"/>
                <field name="total_borrowed"/>
                <field name="total_late"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_library_member_form" model="ir.ui.view">
        <field name="name">library.member.form</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="member_code" readonly="1"/>
                        <field name="name"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="status"/>
                    </group>

                    <group>
                        <field name="total_borrowed" readonly="1"/>
                        <field name="total_late" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_library_member" model="ir.actions.act_window">
        <field name="name">Members</field>
        <field name="res_model">library.member</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>