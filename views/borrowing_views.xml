<odoo>

    <!-- list -->
    <record id="view_library_borrowing_list" model="ir.ui.view">
        <field name="name">library.borrowing.list</field>
        <field name="model">library.borrowing</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="member_id"/>
                <field name="borrow_date"/>
                <field name="due_date"/>
                <field name="state"/>
                <field name="fine_amount"/>
            </list>
        </field>
    </record>

    <!-- FORM -->
    <record id="view_library_borrowing_form" model="ir.ui.view">
        <field name="name">library.borrowing.form</field>
        <field name="model">library.borrowing</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm"
                            type="object"
                            string="Confirm"
                            invisible="state != 'draft'"
                            class="btn-primary"/>

                    <button name="action_return"
                            type="object"
                            string="Return"
                            invisible="state not in ['confirmed','late']"
                            class="btn-success"/>

                    <button name="action_set_draft"
                            type="object"
                            string="Reset to Draft"
                            invisible="state not in ['confirmed','late']"
                            class="btn-secondary"/>

                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,late,returned"/>
                </header>

                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="member_id"/>
                        <field name="borrow_date"/>
                        <field name="due_date"/>
                        <field name="return_date" readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Books">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="book_id"/>
                                    <field name="quantity"/>
                                    <field name="returned_qty"/>
                                </list>
                            </field>
                        </page>
                    </notebook>

                    <group>
                        <field name="total_books" readonly="1"/>
                        <field name="fine_amount" readonly="1"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_library_borrowing" model="ir.actions.act_window">
        <field name="name">Borrowings</field>
        <field name="res_model">library.borrowing</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>