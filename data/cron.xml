<odoo>

    <record id="ir_cron_library_membership_expiry" model="ir.cron">
        <field name="name">Library Membership Expiry Check</field>
        <field name="model_id" ref="model_library_member"/>
        <field name="state">code</field>
        <field name="code">model._cron_check_membership_expiry()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

</odoo>